# BROKR — Apache configuration for static multi-page site
# Each section lives in its own directory with an index.html.
# Apache serves index.html automatically when a directory is requested.

Options -MultiViews -Indexes
DirectoryIndex index.html

# Optional: redirect old SPA routes (without trailing slash) to directory form
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(nosotros|beneficios|contactanos)$ /$1/ [R=301,L]
